# Backend Port Configuration
PORT=5000

# Database Connection String
# For Local MongoDB: mongodb://127.0.0.1:27017/jobtracker
# For MongoDB Atlas: mongodb+srv://<username>:<password>@cluster0.xxxx.mongodb.net/jobtracker
MONGO_URI=mongodb://127.0.0.1:27017/jobtracker

# JWT Authentication Secret Key (Any long random string)
JWT_SECRET=your_super_secret_jwt_key_here
